[sub_resource type="GDScript" id="GDScript_ir8iy"]
script/source = "extends Area2D

@onready var world = get_node(\"/root/Node2D/World\")

func _ready() -> void:
	body_entered.connect(_on_body_entered)
	body_exited.connect(_on_body_exited)


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass

func _on_body_entered(body):
	if body.has_method(\"set_deposit_zone\"):
		body.set_deposit_zone(true, self)
	
func _on_body_exited(body):
	if body.has_method(\"set_deposit_zone\"):
		body.set_deposit_zone(false, self)

func update_world(amount):
	world.update_state(amount)
"

