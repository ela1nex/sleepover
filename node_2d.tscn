[sub_resource type="GDScript" id="GDScript_4d7sh"]
script/source = "extends CharacterBody2D

const SPEED = 50.0
const JUMP_VELOCITY = -200.0

@onready var _animated_sprite = $AnimatedSprite2D
var idle_timer = 0
var move_timer = 0
var collected_whispers = []
@export var max_whispers = 5
var total_deposited = 0
var can_deposit = false
var deposit_node = null

func _process(delta: float) -> void:
	if can_deposit:
		deposit()
	$RichTextLabel.text = \"[font_size=16][pulse freq=0.5]\"+str(collected_whispers.size())+\"[/pulse]\"

func _physics_process(delta: float) -> void:
	# Add the gravity.
	if not is_on_floor():
		velocity += get_gravity() * delta

	# Handle jump.
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = JUMP_VELOCITY

	# Get the input direction and handle the movement/deceleration.
	# As good practice, you should replace UI actions with custom gameplay actions.
	var direction := Input.get_axis(\"ui_left\", \"ui_right\")
	if direction:
		velocity.x = direction * SPEED
		_animated_sprite.play(\"walk\")
		_animated_sprite.flip_h = velocity.x < 0
		if move_timer % 40 == 0:
			$AudioStreamPlayer2D3.play()
		idle_timer = 0
		move_timer += 1
	else:
		velocity.x = move_toward(velocity.x, 0, SPEED)
		if idle_timer == 20:
			_animated_sprite.play(\"idle\")
			_animated_sprite.frame = 0
			_animated_sprite.stop()
		if idle_timer == 100:
			_animated_sprite.play(\"idle\")
		move_timer = 0
		idle_timer += 1

	move_and_slide()

func collect_whisper(whisper):
	if collected_whispers.size() >= max_whispers:
		return
	$AudioStreamPlayer2D.play()
	whisper.queue_free()
	collected_whispers.append(whisper)

func set_deposit_zone(state, node):
	can_deposit = state
	deposit_node = node

func deposit():
	if collected_whispers.size() > 0:
		total_deposited += collected_whispers.size();
		collected_whispers.clear()
		$AudioStreamPlayer2D2.play()
		deposit_node.update_world(total_deposited)
"

