script/source = "extends Node2D

var whisper_scene = preload(\"res://whisper.tscn\")
var tree_scene = preload(\"res://tree.tscn\")
@export var whispers = 10
var walkable_tiles = []
@onready var map_layer = $World/Node2D/Walkable
var cell_size = Vector2(16, 16)

func _ready():
	for cell in map_layer.get_used_cells():
		walkable_tiles.append(cell)
	
	spawn_whispers(cell_size)

@onready var mat = $Player/CanvasLayer/ColorRect.material 
func update_state(amount): 
	var t = clamp(amount / 10.0, 0.0, 1.0) 
	t = t * t 
	mat.set_shader_parameter(\"color_amount\", t)

func spawn_whispers(cell_size: Vector2):
	if walkable_tiles.size() == 0:
		print(\"no tiles\")
		return
	for i in range(whispers):
		var cell = walkable_tiles[i]
		var world_pos = Vector2()
		world_pos.x = (cell.x + 0.5) * cell_size.x
		world_pos.y = (cell.y) * cell_size.y

		var w = whisper_scene.instantiate()
		w.position = world_pos
